# =============================================================================
# hgraph_platform_tools — Environment Configuration
# =============================================================================
# Copy this file to .env and fill in the values for your environment.
# Never commit .env to version control.
# =============================================================================

# --- SMTP / Email ---
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SENDER_EMAIL=
RECIPIENT_EMAIL=

# --- Database ---
ENTITLEMENTS_DB_PATH=hgraph_entitlements.db
STATIC_DATA_DB_PATH=static_data.db

# --- API ---
STATIC_DATA_API_URL=http://localhost:8080/api/counterparties

# --- Kafka ---
KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# --- Trade Messaging ---
MESSAGE_SENDER_ID=hgraph_platform
MESSAGE_TARGET_ID=booking_system
MESSAGE_VERSION=1.0

# --- Notification Templates ---
NOTIFICATION_TEMPLATE_DIR=hgraph_notification/templates
